{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-push-quality-checks.py\"",
            "timeout": 600000
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/require-review.py\"",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
